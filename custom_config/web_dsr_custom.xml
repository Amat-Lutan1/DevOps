--><web-app xmlns="http://java.sun.com/xml/ns/j2ee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.4" xsi:schemaLocation="http://java.sun.com/xml/ns/j2ee http://java.sun.com/xml/ns/j2ee/web-app_2_4.xsd">
    <!-- Version: 9.0.0.1 build #IF020 -->
    <display-name>DecisionService</display-name>
    <!--  ================================================================= -->
    <!--  C O N T E X T - P A R A M                                         -->
    <!--  ================================================================= -->
    <!-- Specify the rulesession execution provider
		Possible values are : J2SE , POJO
		J2SE : Tomcat and Liberty
		POJO : Others supported platforms
	-->
    <context-param>
        <param-name>ExecutionProvider</param-name>
        <param-value>J2SE</param-value>
    </context-param>
    <!-- Specify if the DecisionServiceId is generated in the WSDL
		Possible values are : Latest, 7.0, 7.1, 7.1.1.3
		Latest : Generate wsdl and execute with the latest HTDS feature.
		7.0 : Generate the WSDL and execute the ruleset with the 7.0 format.
		7.1 : Generate the WSDL and execute the ruleset with the 7.1 format.
		7.1.1.3 : Generate the WSDL and execute the ruleset with the 7.1.1.3 format.
	-->
    <context-param>
        <param-name>Compatibility</param-name>
        <param-value>Latest</param-value>
    </context-param>
    <!-- Specify the root name of used to register the Decision MBean
		Use this parameter to deploy multiple instance of HTDS into the same server.
		Default: HTDS 
	-->
    <context-param>
        <param-name>DecisionServicePrefix</param-name>
        <param-value>HTDS</param-value>
    </context-param>
    <!-- Specify if whether the interceptor feature are is enabled for each HTDS execution
		Possible values are : true, false
		true : interceptor is enabled
		false : interceptor is disabled
	-->
    <context-param>
        <param-name>InterceptorEnabled</param-name>
        <param-value>false</param-value>
    </context-param>
    <!-- Specify whether the parsing of the ruleset is asynchronous or not for all HTDS executions.
		Possible values are : true, false
		true : asynchronous ruleset parsing enabled
		false : force execution of the most up-to-date version of the ruleset
	-->
    <context-param>
        <param-name>AsynchronousRulesetParsing</param-name>
        <param-value>false</param-value>
    </context-param>
    <context-param>
        <description>http://www.jboss.org/community/docs/DOC-10182</description>
        <param-name>org.jboss.jbossfaces.WAR_BUNDLES_JSF_IMPL</param-name>
        <param-value>true</param-value>
    </context-param>
    <context-param>
        <param-name>QualifyElementsInParametersNamespaceForWSDL</param-name>
        <param-value>false</param-value>
    </context-param>
    <!-- Specify the timezone in which dates are expressed in case they do not contain timezone information,
		for the REST JSON execution endpoint.
		Possible values are : default, server, or a timezone identifier.
		default : no override of the timezone used by the JSON parser (GMT) 
		server : override of the timezone used by the JSON parser to use the JVM's default timezone
		a timezone identifier : override of the timezone used by the JSON parser to use the specified timezone, if it is a valid timezone 
	-->
    <context-param>
        <param-name>DefaultTimeZoneForJsonDeserialization</param-name>
        <param-value>default</param-value>
    </context-param>
    <!-- Specify whether to check for empty JSON requests and reject them or not.
		 Default is 'true' but may impact performance in case request documents are large.
	-->
    <context-param>
        <param-name>CheckEmptyJsonRequests</param-name>
        <param-value>true</param-value>
    </context-param>
    <!-- Specify whether to force the inclusion of null values in JSON responses ({ "fieldName": null})  
	when corresponding fields are decorated with JAXB annotations like @XmlElement.
	-->
    <context-param>
        <param-name>forceSerializationOfNullFieldsDecoratedWithJAXBAnnotations</param-name>
        <param-value>false</param-value>
    </context-param>
    <!-- Specify the duration in hours after which the JSON serializer will be reset.
	-->
    <context-param>
        <param-name>ResetJsonMapperElapsedHoursThreshold</param-name>
        <param-value>24</param-value>
    </context-param>
    <!-- Specify whether to emit an event when an execution request cannot actually lead to an execution of a ruleset, 
	because the request itself is invalid or does not represent the paramaters correctly or completely enough.
	It still requires that the event emitter is enabled for that ruleset.
	-->
    <context-param>
        <param-name>EmitErrorEventOnRulesetNotExecuted</param-name>
        <param-value>false</param-value>
    </context-param>
    <context-param>
        <param-name>InfoRulesFiredPropertiesFilter</param-name>
        <param-value>false</param-value>
    </context-param>
    <!--  ================================================================= -->
    <!--  F I L T E R                                                       -->
    <!--  ================================================================= -->
    <filter>
        <filter-name>response-headers</filter-name>
        <filter-class>com.ibm.rules.htds.ResponseHeaderFilter</filter-class>
        <init-param>
            <param-name>X-Content-Type-Options</param-name>
            <param-value>nosniff</param-value>
        </init-param>
        <init-param>
            <param-name>X-XSS-Protection</param-name>
            <param-value>1; mode=block</param-value>
        </init-param>
        <init-param>
            <param-name>Access-Control-Allow-Credentials</param-name>
            <param-value>false</param-value>
        </init-param>
        <init-param>
            <param-name>Access-Control-Allow-Origin</param-name>
            <param-value>null</param-value>
        </init-param>
        <init-param>
            <param-name>Content-Security-Policy</param-name>
            <param-value>{"/ws":"default-src 'none'",
     		"/rest":"default-src 'none'",
     		".*":"frame-ancestors default-src 'self' 'unsafe-inline' 'unsafe-eval'",
     		"[web_browsers]":"frame-ancestors default-src 'self' 'unsafe-inline' 'unsafe-eval'"}</param-value>
        </init-param>
    </filter>
    <!--  ================================================================= -->
    <!--  F I L T E R - M A P P I N G                                       -->
    <!--  ================================================================= -->
    <filter-mapping>
        <filter-name>response-headers</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    <!--  ================================================================= -->
    <!--  L I S T E N E R                                                   -->
    <!--  ================================================================= -->
    <listener>
        <listener-class>com.ibm.rules.htds.servlet.DecisionServiceManager</listener-class>
    </listener>
    <!--  ================================================================= -->
    <!--  S E R V L E T                                                     -->
    <!--  ================================================================= -->
    <servlet>
        <servlet-name>WebserviceServlet</servlet-name>
        <servlet-class>ilog.rules.res.decisionservice.web.IlrWebServiceServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RESTDecisionService</servlet-name>
        <servlet-class>com.ibm.rules.htds.servlet.RESTDecisionServiceServlet</servlet-class>
    </servlet>
    <!--  ================================================================= -->
    <!--  S E R V L E T - M A P P I N G                                     -->
    <!--  ================================================================= -->
    <servlet-mapping>
        <servlet-name>WebserviceServlet</servlet-name>
        <url-pattern>/ws/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RESTDecisionService</servlet-name>
        <url-pattern>/rest/*</url-pattern>
    </servlet-mapping>
    <!--  ================================================================= -->
    <!--  W E L C O M E - F I L E - L I S T                                 -->
    <!--  ================================================================= -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <!--  ================================================================= -->
    <!--  E R R O R - P A G E                                               -->
    <!--  ================================================================= -->
    <error-page>
        <exception-type>javax.servlet.ServletException</exception-type>
        <location>/error.jsp</location>
    </error-page>
    <!--  ================================================================= -->
    <!--  R E S O U R C E - R E F                                           -->
    <!--  ================================================================= -->
    <resource-ref>
        <res-ref-name>jdbc/resdatasource</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
        <res-sharing-scope>Unshareable</res-sharing-scope>
    </resource-ref>
    <resource-ref>
        <res-ref-name>eis/XUConnectionFactory</res-ref-name>
        <res-type>javax.resource.cci.ConnectionFactory</res-type>
        <res-auth>Application</res-auth>
        <res-sharing-scope>Unshareable</res-sharing-scope>
    </resource-ref>
    <!--  ================================================================= -->
    <!--  SECURITY                                                          -->
    <!--  ================================================================= -->
